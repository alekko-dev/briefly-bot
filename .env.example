TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OWNER_ID=your_telegram_user_id_here
OPENAI_API_KEY=your_api_key_here
# For a custom LLM endpoint (e.g. local Ollama, OpenRouter), set this.
# Leave commented out to use the default OpenAI API.
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Comma-separated ISO 639-1 codes for languages you understand (no translation needed)
NO_TRANSLATE_LANGS=en,ru
# Language to translate summaries into for all other videos
TARGET_LANG=English
